# ── NexusAI Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env to Git.

# Groq API key — get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Model to use (default: llama3-70b-8192)
GROQ_MODEL=llama3-70b-8192

# Deployment environment: development | production
ENV=development

# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS_STR=http://localhost:5173,http://localhost:3000
